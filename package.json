{
  "name": "ia-financeira-whatsapp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "corepack pnpm -r --parallel dev",
    "build": "corepack pnpm -r build",
    "test": "corepack pnpm -r test",
    "lint": "corepack pnpm -r lint",
    "typecheck": "corepack pnpm -r typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:validate": "corepack pnpm --filter @ia-financeira/database prisma:validate",
    "db:generate": "corepack pnpm --filter @ia-financeira/database prisma:generate",
    "db:migrate": "corepack pnpm --filter @ia-financeira/database prisma:migrate",
    "db:seed": "corepack pnpm --filter @ia-financeira/database prisma:seed"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@types/node": "^24.0.3",
    "eslint": "^9.30.1",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.34.1",
    "vitest": "^3.2.4"
  },
  "packageManager": "pnpm@10.12.4"
}
